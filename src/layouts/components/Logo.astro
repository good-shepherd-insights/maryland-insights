---
import config from "@/config/config.json";
import ImageMod from "./ImageMod.astro";

const {
  src,
  className,
  width,
  height,
  style,
}: {
  src?: string;
  className?: string;
  width?: number;
  height?: number;
  style?: any;
} = Astro.props;

const {
  logo,
  logo_width,
  logo_height,
  logo_text,
  title,
}: {
  logo: string;
  logo_width: any;
  logo_height: any;
  logo_text: string;
  title: string;
} = config.site;
---

<a href="/" class={`navbar-brand inline-block flex items-center gap-2`}>
  {
    src || logo ? (
      <>
        <ImageMod
          src={src ? src : logo}
          class={`inline-block ${className ? className : ""}`}
          width={width ? width * 2 : logo_width.replace("px", "") * 2}
          height={height ? height * 2 : logo_height.replace("px", "") * 2}
          alt={title}
          style={
            style
              ? style
              : {
                  height:
                    (height ? height : logo_height.replace("px", "")) + "px",
                  width: (width ? width : logo_width.replace("px", "")) + "px",
                }
          }
          format={(src || logo).endsWith(".svg") ? "svg" : "webp"}
        />
        <span class="font-black text-text-dark text-xl tracking-tighter ml-1" style="text-shadow: 0 1px 0 rgba(0,0,0,0.15);">Maryland Insights</span>
      </>
    ) : logo_text ? (
      logo_text
    ) : (
      title
    )
  }
</a>
