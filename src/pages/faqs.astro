---
import Base from "@/layouts/Base.astro";
import { getListPage } from "@/lib/contentParser.astro";
import { plainify } from "@/lib/utils/textConverter";
import CallToAction from "@/partials/CallToAction.astro";
import PageHeader from "@/partials/PageHeader.astro";
import Testimonial from "@/partials/Testimonial.astro";
import Faqs from "@/partials/Faqs.astro";
import type { FAQPage, Question } from "schema-dts";

const pageIndex = await getListPage("faqs", "-index");
if (pageIndex.data.draft) return Astro.redirect("/404");

const { title, description } = pageIndex.data;

const faqsComponent = await getListPage("faqs", "-general");
const faqs_section = faqsComponent.data;

const faqSchema: FAQPage = {
  "@type": "FAQPage",
  mainEntity: faqs_section.faqs_list.map(
    (faq: any) =>
      ({
        "@type": "Question",
        name: plainify(faq.question),
        acceptedAnswer: {
          "@type": "Answer",
          text: plainify(faq.answer),
        },
      }) as Question,
  ),
};
---

<Base {...pageIndex.data} schema={[faqSchema]}>
  <PageHeader title={title} description={description} />

  <Faqs data={faqs_section} />

  <Testimonial />
  <CallToAction />
</Base>
